# ==========================================
# STELAIR BACKEND - VARIABLES D'ENVIRONNEMENT
# ==========================================
# Copiez ce fichier en ".env" et remplissez vos vraies valeurs.
# Ne JAMAIS commit le fichier ".env" (il est deja dans .gitignore).

# Port du serveur (Railway definit sa propre variable PORT automatiquement)
PORT=5000
 TCP    0.0.0.0:5000           0.0.0.0:0              LISTENING       27472
# Environnement
NODE_ENV=development

# MongoDB Atlas - collez votre chaine de connexion complete
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/stelair?retryWrites=true&w=majority

# Secret pour signer les tokens JWT de connexion admin (mettre une longue chaine aleatoire)
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Identifiants du compte administrateur cree automatiquement au premier lancement (npm run seed)
ADMIN_EMAIL=admin@stelair.com
ADMIN_PASSWORD=ChangeMoiMaintenant123!

# Cloudinary (Dashboard > Account Details)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# URL du frontend deploye (Netlify) - utilisee pour la config CORS
CLIENT_URL=http://localhost:5173

# Chemin secret pour acceder a la page d'administration (change le lien discret sur le site)
ADMIN_ROUTE_SECRET=backstage
