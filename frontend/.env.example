# Copiez ce fichier en ".env" a la racine de /frontend

# URL de l'API backend (locale en dev, Railway en production)
VITE_API_URL=http://localhost:5000/api

# Chemin secret de la page admin (doit correspondre a une valeur difficile a deviner)
# Exemple : si vous mettez "backstage-2026", la page admin sera sur /backstage-2026
VITE_ADMIN_PATH=backstage
